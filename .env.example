# ============================================================
# Omni Ecomm Engine — environment template
# Copy to .env.production on Hetzner host. Each stage worker
# reads ONLY the keys scoped below it (stage isolation).
# ============================================================

# ---- Shared infra (all workers + web) ----
NODE_ENV=production
APP_URL=https://engine.5-78-187-35.sslip.io
PORT=8005

# Hetzner self-hosted Supabase (existing)
SUPABASE_URL=https://5-78-187-35.sslip.io
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgres://postgres:postgres@host.docker.internal:5433/postgres

# Redis (BullMQ) — existing on host
REDIS_URL=redis://host.docker.internal:6379

# Storage (Supabase storage bucket)
STORAGE_BUCKET=ecomm-assets

# Auth (magic-link approval tokens)
JWT_SECRET=
APPROVAL_TOKEN_TTL_DAYS=7

# ---- Stage 2 — process-worker ----
ANTHROPIC_API_KEY=
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_COMPLEX_MODEL=claude-opus-4-7

# ---- Stage 3 — generate-worker ----
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ---- Stage 4 — audit-worker ----
AUDIT_VISION_MODEL=claude-opus-4-7

# ---- Stage 8 — notify-worker ----
RESEND_API_KEY=
RESEND_FROM=engine@omnichannelsol.com
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=

# ---- Stage 9 — export-worker ----
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
